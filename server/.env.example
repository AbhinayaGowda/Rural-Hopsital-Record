# --- Server (Render injects PORT automatically; set the rest in Render dashboard) ---
PORT=4000
NODE_ENV=development

# --- Supabase (set in Render dashboard) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- CORS (comma-separated; include both local dev origin and Vercel prod URL) ---
# e.g. CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173
